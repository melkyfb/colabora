# Copie para .env e ajuste. .env NAO vai pro git (ver .gitignore).

# ── MySQL ──
MYSQL_ROOT_PASSWORD=root_dev_pw
MYSQL_DATABASE=nyx
MYSQL_USER=nyx
MYSQL_PASSWORD=nyx_dev_pw
MYSQL_PORT=3306

# ── PHPMyAdmin ──
PHPMYADMIN_PORT=8080

# ── Redis ──
REDIS_PORT=6379

# ── OpenSearch ──
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# ── Cerbos ──
CERBOS_HTTP_PORT=3592
CERBOS_GRPC_PORT=3593

# ── Backend API (FastAPI, Fase 2) ──
BACKEND_PORT=8000
JWT_SECRET=troque-por-segredo-forte-com-32-bytes-ou-mais
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
HOCUSPOCUS_WEBHOOK_SECRET=troque-por-segredo-webhook
INTERNAL_API_KEY=troque-por-chave-interna-32-bytes-ou-mais

# ── Realtime server (Hocuspocus, Fase 3) ──
HOCUSPOCUS_PORT=1234

# ── RAG (Fase 4) ── local | openai | fake
EMBEDDINGS_PROVIDER=local
# OPENAI_API_KEY=   # so se EMBEDDINGS_PROVIDER=openai ou LLM_PROVIDER=openai

# ── LLM chat (Fase 5) ── claude | openai | ollama | local
LLM_PROVIDER=claude
LLM_MODEL=                 # vazio = default do provider (claude -> claude-opus-4-8)
ANTHROPIC_API_KEY=         # necessario se LLM_PROVIDER=claude
OLLAMA_BASE_URL=http://host.docker.internal:11434
#OPENAI_API_BASE_URL=https://api.openai.com/v1 # se usar um servidor LLM compatível com OpenAI (ex: OpenLLM, LLaMA-Serve, etc). Se não setar, usa o padrão do provider.

# ── Frontend (Fase 5) ──
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173
